# ============================================================
# Git LFS — Configuración para dba_thesis
# Universidad de Investigación e Innovación de México (UIIX)
# ============================================================

# --- Jupyter Notebooks (pueden contener outputs pesados) ---
*.ipynb filter=lfs diff=lfs merge=lfs -text

# --- Archivos de datos grandes ---
*.csv filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.xls filter=lfs diff=lfs merge=lfs -text
*.sav filter=lfs diff=lfs merge=lfs -text
*.dta filter=lfs diff=lfs merge=lfs -text
*.RData filter=lfs diff=lfs merge=lfs -text
*.rds filter=lfs diff=lfs merge=lfs -text

# --- Imágenes y figuras generadas ---
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text

# --- Documentos de tesis (versiones del manuscrito) ---
*.docx filter=lfs diff=lfs merge=lfs -text
*.doc  filter=lfs diff=lfs merge=lfs -text

# --- Archivos de audio/video (si aplica para evidencias) ---
*.mp4  filter=lfs diff=lfs merge=lfs -text
*.mp3  filter=lfs diff=lfs merge=lfs -text
*.wav  filter=lfs diff=lfs merge=lfs -text
