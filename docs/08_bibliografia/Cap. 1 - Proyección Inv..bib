@article{torres_ortega_ecosistemas_2018,
	title = {Ecosistemas para el emprendimiento: {Características} del concepto y su aplicación a la empresa social},
	issn = {2444-3107, 1698-7446},
	shorttitle = {Ecosistemas para el emprendimiento},
	url = {http://www.ehu.eus/ojs/index.php/gezki/article/view/18004},
	doi = {10.1387/reves.18004},
	abstract = {Las distintas aproximaciones que hacen uso del concepto biológico de ecosistema para abordar el fenómeno del emprendimiento subrayan la necesidad de capturar de manera holística todos los factores ambientales que contribuyen al éxito o fracaso de los emprendedores. Si bien este enfoque ha venido ganando una aceptación cada vez mayor entre académicos y policy makers, no puede afirmarse que exista un consenso en cuanto al significado exacto del constructo ecosistema para el emprendimiento. El presente artículo tiene como objetivo principal evaluar las similitudes y diferencias presentes en las distintas versiones del enfoque ecosistémico, con énfasis en el emprendimiento social. Se advierte que, aunque existen premisas comunes, los distintos modelos de ecosistema para el emprendimiento se diferencian en cuanto a los factores que destacan como condicionantes del surgimiento y permanencia de las iniciativas emprendedoras. En el caso del emprendimiento social, dichas diferencias tienen importantes implicaciones de carácter práctico.},
	number = {14},
	urldate = {2024-12-05},
	journal = {Gizarte Ekonomiaren Euskal Aldizkaria - Revista Vasca de Economía Social},
	author = {Torres Ortega, Jorge Antonio},
	month = jun,
	year = {2018},
	pages = {61--76},
}

